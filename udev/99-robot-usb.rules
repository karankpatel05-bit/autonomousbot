# /etc/udev/rules.d/99-robot-usb.rules
#
# Locks USB serial ports so RPLidar always gets /dev/rplidar
# and ESP32 always gets /dev/esp32_motor, regardless of plug order.
#
# USAGE:
#   sudo cp udev/99-robot-usb.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# HOW TO FIND YOUR DEVICE ATTRIBUTES:
#   Plug each USB device one at a time and run:
#   udevadm info -a -n /dev/ttyUSB0 | grep -E 'idVendor|idProduct|serial'
#
# ── RPLidar A1M8 ── (CP210x USB-UART, VID=10c4, PID=ea60)
SUBSYSTEM=="tty", \
  ATTRS{idVendor}=="10c4", \
  ATTRS{idProduct}=="ea60", \
  SYMLINK+="rplidar", \
  MODE="0666"

# ── ESP32 DevKit ── (Silicon Labs CP2102, VID=10c4, PID=ea60)
# If both devices share the same VID:PID (common with CP210x), use the
# USB serial number (ATTRS{serial}) to distinguish them.
# Run the command above and look for ATTRS{serial}=="..." to get the value.
#
# UNCOMMENT and fill in your ESP32 serial number:
# SUBSYSTEM=="tty", \
#   ATTRS{idVendor}=="10c4", \
#   ATTRS{idProduct}=="ea60", \
#   ATTRS{serial}=="YOUR_ESP32_SERIAL_HERE", \
#   SYMLINK+="esp32_motor", \
#   MODE="0666"
#
# ── ESP32 with CH340 USB-UART chip ── (VID=1a86, PID=7523)
SUBSYSTEM=="tty", \
  ATTRS{idVendor}=="1a86", \
  ATTRS{idProduct}=="7523", \
  SYMLINK+="esp32_motor", \
  MODE="0666"

# After applying these rules, use /dev/rplidar and /dev/esp32_motor in your
# launch files instead of /dev/ttyUSB0 and /dev/ttyUSB1.
